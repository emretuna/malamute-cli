{
  "name": "malamute-cli",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./orchestrator": {
      "types": "./dist/orchestrator/index.d.ts",
      "import": "./dist/orchestrator/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./action": {
      "types": "./dist/action/index.d.ts",
      "import": "./dist/action/index.js"
    },
    "./aggregator": {
      "types": "./dist/aggregator/index.d.ts",
      "import": "./dist/aggregator/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    }
  },
  "repository": "git+https://github.com/emretuna/malamute-cli.git",
  "homepage": "https://github.com/emretuna/malamute-cli#readme",
  "bugs": "https://github.com/emretuna/malamute-cli/issues",
  "description": "AI orchestration layer that runs specialized agents during repository events.",
  "keywords": [
    "ai",
    "git",
    "hooks",
    "claude",
    "code-review",
    "pre-commit"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "malamute": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsup && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "commander": "^12",
    "execa": "^9",
    "js-yaml": "^4",
    "simple-git": "^3",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^22",
    "eslint": "^9",
    "prettier": "^3",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^2"
  }
}
