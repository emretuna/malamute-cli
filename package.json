{
  "name": "malamute-cli",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emretuna/malamute-cli"
  },
  "homepage": "https://github.com/emretuna/malamute-cli#readme",
  "bugs": "https://github.com/emretuna/malamute-cli/issues",
  "description": "AI orchestration layer that runs specialized agents during repository events.",
  "keywords": [
    "ai",
    "git",
    "hooks",
    "claude",
    "code-review",
    "pre-commit"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "malamute": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsup && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "commander": "^12",
    "execa": "^9",
    "js-yaml": "^4",
    "simple-git": "^3",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^22",
    "eslint": "^9",
    "prettier": "^3",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^2"
  }
}
