#!/usr/bin/env bash
# malamute hook — do not edit
set -euo pipefail

# Resolve the malamute CLI. Search order:
#   1. malamute on PATH (global or nvm-style install)
#   2. node_modules/.bin/malamute in the current directory
#   3. node_modules/.bin/malamute in any ancestor directory
#      (covers monorepos, sub-repos, and project-local installs)
#   4. Friendly error

if command -v malamute > /dev/null 2>&1; then
  exec malamute run pre-commit "$@"
fi

# Walk up from the current working directory looking for the binary.
# git invokes hooks with GIT_DIR pointing inside the repo, so CWD may be
# anywhere; searching ancestors matches how husky/lefthook locate themselves.
search_dir="$PWD"
while [ "$search_dir" != "/" ]; do
  if [ -x "$search_dir/node_modules/.bin/malamute" ]; then
    exec "$search_dir/node_modules/.bin/malamute" run pre-commit "$@"
  fi
  search_dir="$(dirname "$search_dir")"
done

echo "malamute: CLI not found. Install with 'npm install --save-dev malamute-cli'." >&2
exit 1
